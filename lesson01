<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>About Me — [Your Name]</title>
  <style>
    /* ── Reset & Base ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: Georgia, 'Times New Roman', serif;
      background-color: #f5f1eb;
      color: #2c2c2c;
      line-height: 1.75;
    }

    a { color: #5a3e28; text-decoration: none; }
    a:hover { text-decoration: underline; }

    /* ── Navigation ── */
    nav {
      background-color: #2c2c2c;
      position: sticky;
      top: 0;
      z-index: 100;
    }

    nav ul {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      list-style: none;
      gap: 0;
    }

    nav ul li a {
      display: block;
      padding: 14px 22px;
      color: #f5f1eb;
      font-family: Arial, sans-serif;
      font-size: 0.85rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      transition: background 0.2s;
    }

    nav ul li a:hover {
      background-color: #5a3e28;
      text-decoration: none;
    }

    /* ── Hero / Header ── */
    header {
      background-color: #3b2f1e;
      color: #f5f1eb;
      text-align: center;
      padding: 70px 20px 60px;
    }

    header .avatar {
      width: 130px;
      height: 130px;
      border-radius: 50%;
      background-color: #7a5c3a;
      border: 4px solid #f5f1eb;
      margin: 0 auto 24px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 3rem;
      /* Replace with an <img> tag once you have a photo */
    }

    header h1 {
      font-size: 2.6rem;
      font-weight: normal;
      letter-spacing: 0.04em;
      margin-bottom: 8px;
    }

    header p.tagline {
      font-size: 1.1rem;
      opacity: 0.85;
      font-style: italic;
    }

    /* ── Main Layout ── */
    main {
      max-width: 860px;
      margin: 0 auto;
      padding: 20px 24px 60px;
    }

    /* ── Sections ── */
    section {
      margin-top: 52px;
      padding-top: 8px;
      border-top: 2px solid #d4c4ae;
    }

    section h2 {
      font-size: 1.5rem;
      color: #5a3e28;
      margin-bottom: 16px;
      font-weight: normal;
      letter-spacing: 0.03em;
    }

    section p {
      margin-bottom: 14px;
    }

    /* ── Lists ── */
    ul.bio-list {
      list-style: none;
      padding: 0;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 10px;
      margin-top: 4px;
    }

    ul.bio-list li {
      background-color: #ede5d8;
      border-left: 4px solid #7a5c3a;
      padding: 10px 14px;
      border-radius: 2px;
      font-family: Arial, sans-serif;
      font-size: 0.93rem;
    }

    /* ── Goals Table ── */
    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 8px;
      font-family: Arial, sans-serif;
      font-size: 0.92rem;
    }

    table thead tr {
      background-color: #3b2f1e;
      color: #f5f1eb;
    }

    table th, table td {
      padding: 11px 14px;
      text-align: left;
      border-bottom: 1px solid #d4c4ae;
    }

    table tbody tr:nth-child(even) {
      background-color: #ede5d8;
    }

    /* ── Activities Cards ── */
    .card-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 16px;
      margin-top: 8px;
    }

    .card {
      background-color: #ede5d8;
      border-radius: 4px;
      padding: 18px 16px;
      border-top: 4px solid #7a5c3a;
      font-family: Arial, sans-serif;
    }

    .card h3 {
      font-size: 1rem;
      color: #3b2f1e;
      margin-bottom: 6px;
    }

    .card p {
      font-size: 0.88rem;
      color: #555;
      margin: 0;
    }

    /* ── Quote ── */
    blockquote {
      border-left: 4px solid #7a5c3a;
      padding: 12px 20px;
      margin: 20px 0;
      background-color: #ede5d8;
      font-style: italic;
      color: #4a3828;
    }

    blockquote cite {
      display: block;
      margin-top: 8px;
      font-style: normal;
      font-size: 0.85rem;
      color: #777;
    }

    /* ── Contact ── */
    address {
      font-style: normal;
      font-family: Arial, sans-serif;
      font-size: 0.93rem;
      line-height: 2;
    }

    /* ── Footer ── */
    footer {
      background-color: #2c2c2c;
      color: #bbb;
      text-align: center;
      padding: 22px 20px;
      font-family: Arial, sans-serif;
      font-size: 0.82rem;
    }
  </style>
</head>
